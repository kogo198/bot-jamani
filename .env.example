# ═══════════════════════════════════════════════════════
#  Kiplaa WhatsApp Bot — .env.example  (v2.0)
#  Copy this file to .env and fill in your values.
#  Run:  cp .env.example .env
# ═══════════════════════════════════════════════════════


# ── REQUIRED ─────────────────────────────────────────────

# Your WhatsApp session ID (get it from https://i-tct.com/pair/qr)
SESSION_ID=your_session_id_here


# ── BOT BEHAVIOUR ────────────────────────────────────────

# Command prefix — the symbol before every command (e.g. .ping, !ping)
# Leave empty to use commands without a prefix
PREFIX=.

# Timezone for scheduled messages and time-based features
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Africa/Nairobi

# Hide noisy/internal log spam (recommended: true)
FILTER_NOISE_LOGS=true


# ── DATABASE PERFORMANCE ⚡ ───────────────────────────────

# Number of records to write in one batch (higher = fewer disk writes)
DB_BATCH_SIZE=600

# How often to flush pending writes to disk (milliseconds)
DB_FLUSH_INTERVAL=2000

# Maximum RAM allocated for DB cache in bytes (268435456 = 256 MB)
DB_CACHE_MAX_BYTES=268435456

# Timeout when DB is busy/locked (milliseconds)
DB_BUSY_TIMEOUT_MS=8000


# ── WEB DASHBOARD ────────────────────────────────────────

# Uncomment to enable the web dashboard
#DASHBOARD_ENABLED=true
DASHBOARD_USER=admin
DASHBOARD_PASS=change_me_please

# Port the dashboard runs on
server_port=3007


# ── CLOUDINARY (optional — for image hosting) ────────────

#CLOUDINARY_CLOUD_NAME=your_cloud_name
#CLOUDINARY_API_KEY=your_api_key
#CLOUDINARY_API_SECRET=your_api_secret


# ── OPENWEATHER (optional — for .weather command) ────────

#OPENWEATHER_API_KEY=your_openweather_key


# ── MISTRAL AI (optional — for AI chat features) ─────────

#MISTRAL_API_KEY=your_mistral_key